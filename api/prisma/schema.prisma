// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  projects Project[]
  agents   AgentRole[]
}

model Project {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  boards    Board[]
  tasks     Task[]
}

model ProjectIdeaPlanJob {
  id                    String                   @id @default(uuid())
  workspace_id          String
  project_name          String
  idea                  String
  generation_mode       String                   @default("FAST")
  status                ProjectIdeaPlanJobStatus @default(PENDING)
  error                 String?
  total_features        Int                      @default(0)
  completed_features    Int                      @default(0)
  current_feature_id    String?
  current_feature_title String?
  product_vision        Json
  selected_features     Json
  result_plan           Json?
  created_at            DateTime                 @default(now())
  updated_at            DateTime                 @updatedAt
  started_at            DateTime?
  finished_at           DateTime?
}

model Board {
  id         String   @id @default(uuid())
  project_id String
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  columns BoardColumn[]
}

model BoardColumn {
  id         String   @id @default(uuid())
  board_id   String
  name       String
  order      Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  board Board  @relation(fields: [board_id], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id          String  @id @default(uuid())
  project_id  String
  column_id   String?
  title       String
  description String?

  priority TaskPriority @default(MEDIUM)
  status   TaskStatus   @default(BACKLOG)

  order Int @default(0)

  assignee_role_id    String?
  created_by_agent_id String?

  acceptance_criteria String?
  technical_notes     String?
  test_cases          String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project Project      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  column  BoardColumn? @relation(fields: [column_id], references: [id], onDelete: SetNull)

  assignee_role    AgentRole? @relation("TaskAssigneeRole", fields: [assignee_role_id], references: [id], onDelete: SetNull)
  created_by_agent AgentRole? @relation("TaskCreatedByAgent", fields: [created_by_agent_id], references: [id], onDelete: SetNull)

  comments   TaskComment[]
  agent_runs AgentRun[]
}

model TaskComment {
  id         String   @id @default(uuid())
  task_id    String
  agent_id   String?
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  task  Task       @relation(fields: [task_id], references: [id], onDelete: Cascade)
  agent AgentRole? @relation(fields: [agent_id], references: [id], onDelete: SetNull)
}

model AgentRole {
  id                String        @id @default(uuid())
  workspace_id      String
  name              String
  role              AgentRoleType
  description       String?
  system_prompt     String
  model_provider_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  workspace      Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  model_provider ModelProvider? @relation(fields: [model_provider_id], references: [id], onDelete: SetNull)

  assigned_tasks Task[]        @relation("TaskAssigneeRole")
  created_tasks  Task[]        @relation("TaskCreatedByAgent")
  comments       TaskComment[]
  runs           AgentRun[]
}

model AgentRun {
  id       String  @id @default(uuid())
  task_id  String?
  agent_id String

  status AgentRunStatus @default(PENDING)

  input  String
  output String?
  error  String?

  started_at  DateTime?
  finished_at DateTime?
  created_at  DateTime  @default(now())

  task  Task?     @relation(fields: [task_id], references: [id], onDelete: SetNull)
  agent AgentRole @relation(fields: [agent_id], references: [id], onDelete: Cascade)
}

model ModelProvider {
  id         String            @id @default(uuid())
  name       String
  type       ModelProviderType
  base_url   String?
  model_name String
  api_key    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  agents AgentRole[]
}

model Document {
  id          String             @id @default(uuid())
  project_id  String?
  title       String
  content     String?
  source_type DocumentSourceType @default(MANUAL)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  chunks DocumentChunk[]
}

model DocumentChunk {
  id          String @id @default(uuid())
  document_id String
  content     String
  index       Int
  embedding   Json?

  created_at DateTime @default(now())

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  READY
  IN_PROGRESS
  REVIEW
  TESTING
  DONE
}

enum AgentRoleType {
  PM
  DEVELOPER
  DESIGNER
  QC
  DEVOPS
  WRITER
  SUPPORT
}

enum AgentRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum ModelProviderType {
  OLLAMA
  OPENAI
  ANTHROPIC
  GEMINI
  LOCAL
}

enum DocumentSourceType {
  MANUAL
  UPLOAD
  CODEBASE
  TASK
  URL
}

enum ProjectIdeaPlanJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}
