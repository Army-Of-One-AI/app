// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  Owner
  Admin
  Member
}

enum TeamRole {
  Leader
  Member
}

enum ProjectRole {
  Owner
  Product_Owner
  Project_Manager
  Tech_Lead
  Designer
  Developer
  QC
  DevOps
  Member
}

enum TaskStatus {
  Backlog
  Todo
  In_Progress
  Review
  Done
  Canceled
}

enum TaskPriority {
  Low
  Medium
  High
  Urgent
}

enum DocumentStatus {
  Draft
  Published
  Archived
}

enum ProjectStatus {
  Planning
  Active
  On_Hold
  Completed
  Archived
}

model Workspace {
  id String @id @default(uuid())

  name     String  @unique
  slug     String  @unique
  logo_url String?

  teams    Team[]
  projects Project[]
  members  WorkspaceMember[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
}

model WorkspaceMember {
  id Int @id @default(autoincrement())

  role WorkspaceRole @default(Member)

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  member_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([workspace_id, member_id])
  @@index([workspace_id])
  @@index([member_id])
}

model User {
  id String @id @default(uuid())

  username  String  @unique
  email     String  @unique
  is_active Boolean @default(false)

  userInfo          UserInfo?
  teams             TeamMember[]    @relation(name: "UserTeams")
  projectMembers    ProjectMember[]
  created_tasks     Task[]          @relation(name: "TaskCreator")
  assigned_tasks    Task[]          @relation(name: "TaskAssignee")
  created_documents Document[]      @relation(name: "DocumentCreator")

  created_at       DateTime          @default(now())
  updated_at       DateTime?         @updatedAt
  workspaceMembers WorkspaceMember[]
}

model UserInfo {
  id String @id @default(uuid())

  full_name  String?
  title      String?
  phone_no   String?
  avatar_url String?

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @unique

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
}

model Team {
  id String @id @default(uuid())

  name        String
  slug        String
  description String?
  icon_url    String?

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  members TeamMember[] @relation("TeamMembers")

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@unique([workspace_id, slug])
  @@index([slug])
}

model TeamMember {
  id Int @id @default(autoincrement())

  role TeamRole @default(Member)

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade, name: "UserTeams")
  member_id String

  team    Team   @relation(fields: [team_id], references: [id], onDelete: Cascade, name: "TeamMembers")
  team_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([team_id, member_id])
  @@index([team_id])
  @@index([member_id])
}

model Project {
  id String @id @default(uuid())

  name        String
  slug        String
  description Json?

  status       ProjectStatus @default(Planning)
  start_date   DateTime?
  target_date  DateTime?
  completed_at DateTime?

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  members   ProjectMember[]
  tasks     Task[]
  documents Document[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@unique([workspace_id, slug])
  @@index([workspace_id])
  @@index([status])
  @@index([workspace_id, status])
}

model ProjectMember {
  id Int @id @default(autoincrement())

  role ProjectRole @default(Member)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  member_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([project_id, member_id])
  @@index([project_id])
  @@index([member_id])
}

model Task {
  id String @id @default(uuid())

  title       String
  description Json?

  status   TaskStatus   @default(Backlog)
  priority TaskPriority @default(Medium)

  estimate     Int?
  due_date     DateTime?
  started_at   DateTime?
  completed_at DateTime?

  position Decimal @default(0)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  assignee    User?   @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
  assignee_id String?

  creator    User   @relation("TaskCreator", fields: [creator_id], references: [id], onDelete: Restrict)
  creator_id String

  parent_task    Task?   @relation("SubTasks", fields: [parent_task_id], references: [id], onDelete: SetNull)
  parent_task_id String?

  sub_tasks Task[] @relation("SubTasks")

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@index([project_id])
  @@index([assignee_id])
  @@index([creator_id])
  @@index([status])
  @@index([due_date])
  @@index([parent_task_id])
  @@index([project_id, status])
  @@index([project_id, position])
  @@index([project_id, assignee_id])
  @@index([project_id, due_date])
}

model Document {
  id String @id @default(uuid())

  title   String
  slug    String
  content Json?
  status  DocumentStatus @default(Draft)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  creator    User   @relation("DocumentCreator", fields: [creator_id], references: [id], onDelete: Restrict)
  creator_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@unique([project_id, slug])
  @@index([project_id])
  @@index([creator_id])
  @@index([status])
  @@index([project_id, status])
}
