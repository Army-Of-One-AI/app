// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  Owner
  Admin
  Member
}

enum TeamRole {
  Leader
  Member
}

enum ProjectRole {
  Owner
  Product_Owner
  Project_Manager
  Tech_Lead
  Designer
  Developer
  QC
  DevOps
  Member
}

enum TaskStatus {
  Backlog
  Todo
  In_Progress
  Review
  Done
  Canceled
}

enum TaskPriority {
  Low
  Medium
  High
  Urgent
}

enum DocumentStatus {
  Draft
  Published
  Archived
}

enum ProjectStatus {
  Planning
  Active
  On_Hold
  Completed
  Archived
}

enum TaskActivity {
  TASK_CREATED
  TASK_ARCHIVED
  TASK_RESTORED
  TASK_DELETED

  TITLE_CHANGED
  DESCRIPTION_UPDATED

  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNEE_CHANGED
  DUE_DATE_CHANGED

  SUBTASK_CREATED
  SUBTASK_REMOVED

  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED
}

enum InboxItemType {
  TASK_ASSIGNED
  PROJECT_ADDED
  WORKSPACE_INVITED
  COMMENT_MENTIONED
  DUE_DATE_CHANGED
}

enum SprintStatus {
  Planned
  Active
  Completed
  Canceled
}

model Workspace {
  id String @id @default(uuid())

  name     String  @unique
  slug     String  @unique
  logo_url String?

  teams            Team[]
  projects         Project[]
  members          WorkspaceMember[]
  lastUsedUsers    User[]
  workspaceInvites WorkspaceInvite[]
  inboxItems       InboxItem[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
}

model WorkspaceMember {
  id Int @id @default(autoincrement())

  role WorkspaceRole @default(Member)

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  member_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([workspace_id, member_id])
  @@index([workspace_id])
  @@index([member_id])
}

model User {
  id String @id @default(uuid())

  username  String  @unique
  email     String  @unique
  is_active Boolean @default(false)

  userInfo                UserInfo?
  teams                   TeamMember[]      @relation(name: "UserTeams")
  projectMembers          ProjectMember[]
  created_tasks           Task[]            @relation(name: "TaskCreator")
  assigned_tasks          Task[]            @relation(name: "TaskAssignee")
  created_documents       Document[]        @relation(name: "DocumentCreator")
  workspaceMembers        WorkspaceMember[]
  createdWorkspaceInvites WorkspaceInvite[]

  inboxItems     InboxItem[]
  sentInboxItems InboxItem[] @relation("InboxActor")

  taskComments TaskComment[]

  lastUsedWorkspace      Workspace? @relation(fields: [last_used_workspace_id], references: [id], onDelete: SetNull)
  last_used_workspace_id String?

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
}

model UserInfo {
  id String @id @default(uuid())

  full_name  String?
  title      String?
  phone_no   String?
  avatar_url String?

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String @unique

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
}

model Team {
  id String @id @default(uuid())

  name        String
  slug        String
  description String?
  icon_url    String?

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  members TeamMember[] @relation("TeamMembers")

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@unique([workspace_id, slug])
  @@index([slug])
}

model TeamMember {
  id Int @id @default(autoincrement())

  role TeamRole @default(Member)

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade, name: "UserTeams")
  member_id String

  team    Team   @relation(fields: [team_id], references: [id], onDelete: Cascade, name: "TeamMembers")
  team_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([team_id, member_id])
  @@index([team_id])
  @@index([member_id])
}

model Project {
  id String @id @default(uuid())

  name        String
  slug        String
  description Json?

  status         ProjectStatus @default(Planning)
  start_date     DateTime?
  target_date    DateTime?
  completed_at   DateTime?
  is_member_only Boolean       @default(false)

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  members    ProjectMember[]
  tasks      Task[]
  documents  Document[]
  epics      Epic[]
  inboxItems InboxItem[]
  sprints    Sprint[]

  created_at DateTime    @default(now())
  updated_at DateTime?   @updatedAt
  deleted_at DateTime?
  labels     TaskLabel[]

  @@unique([workspace_id, slug])
  @@index([workspace_id])
  @@index([status])
  @@index([workspace_id, status])
}

model ProjectMember {
  id Int @id @default(autoincrement())

  role ProjectRole @default(Member)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  member    User   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  member_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([project_id, member_id])
  @@index([project_id])
  @@index([member_id])
}

model Task {
  id String @id @default(uuid())

  title       String
  description Json?

  status   TaskStatus   @default(Backlog)
  priority TaskPriority @default(Medium)

  estimate     Int?
  due_date     DateTime?
  started_at   DateTime?
  completed_at DateTime?
  archived_at  DateTime?

  position Decimal @default(0)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  assignee    User?   @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
  assignee_id String?

  creator    User   @relation("TaskCreator", fields: [creator_id], references: [id], onDelete: Restrict)
  creator_id String

  parent_task    Task?   @relation("SubTasks", fields: [parent_task_id], references: [id], onDelete: SetNull)
  parent_task_id String?

  sub_tasks Task[] @relation("SubTasks")

  epic    Epic?   @relation(fields: [epic_id], references: [id], onDelete: SetNull)
  epic_id String?

  sprint    Sprint? @relation(fields: [sprint_id], references: [id])
  sprint_id String?

  inboxItems InboxItem[]

  created_at   DateTime      @default(now())
  updated_at   DateTime?     @updatedAt
  deleted_at   DateTime?
  taskComments TaskComment[]
  labels       TaskLabel[]

  @@index([project_id])
  @@index([assignee_id])
  @@index([creator_id])
  @@index([status])
  @@index([due_date])
  @@index([parent_task_id])
  @@index([project_id, status])
  @@index([project_id, position])
  @@index([project_id, assignee_id])
  @@index([project_id, due_date])
}

model Document {
  id String @id @default(uuid())

  title   String
  slug    String
  content Json?
  status  DocumentStatus @default(Draft)

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  creator    User   @relation("DocumentCreator", fields: [creator_id], references: [id], onDelete: Restrict)
  creator_id String

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@unique([project_id, slug])
  @@index([project_id])
  @@index([creator_id])
  @@index([status])
  @@index([project_id, status])
}

model TaskActivityLog {
  id String @id @default(uuid())

  task_id    String
  project_id String
  user_id    String?

  actor_name_snapshot   String?
  actor_avatar_snapshot String?

  activity TaskActivity
  metadata Json?

  created_at DateTime @default(now())

  @@index([task_id, created_at(sort: Desc), id(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
  @@index([project_id, created_at(sort: Desc)])
}

model WorkspaceInvite {
  id String @id @default(uuid())

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workspace_id String

  email String

  expires_at  DateTime
  accepted_at DateTime?
  revoked_at  DateTime?

  creator    User   @relation(fields: [created_by], references: [id])
  created_by String

  inboxItems InboxItem[]

  created_at DateTime @default(now())

  @@unique([workspace_id, email])
  @@index([email])
  @@index([workspace_id])
}

model Epic {
  id String @id @default(uuid())

  title       String
  description Json?
  color       String?
  position    Int     @default(0)

  start_date DateTime?
  due_date   DateTime?

  archived_at DateTime?
  deleted_at  DateTime?

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  tasks Task[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@index([project_id, deleted_at])
  @@index([project_id, position])
}

model InboxItem {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  actor_id String?
  actor    User?   @relation("InboxActor", fields: [actor_id], references: [id], onDelete: SetNull)

  workspace_id String?
  workspace    Workspace? @relation(fields: [workspace_id], references: [id], onDelete: SetNull)

  project_id String?
  project    Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)

  task_id String?
  task    Task?   @relation(fields: [task_id], references: [id], onDelete: SetNull)

  invite_id String?
  invite    WorkspaceInvite? @relation(fields: [invite_id], references: [id], onDelete: SetNull)

  type InboxItemType

  title    String
  message  String?
  metadata Json?

  read_at     DateTime?
  archived_at DateTime?

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@index([user_id, read_at, created_at(sort: Desc)])
  @@index([user_id, archived_at, created_at(sort: Desc)])
  @@index([workspace_id, created_at(sort: Desc)])
  @@index([project_id, created_at(sort: Desc)])
  @@index([task_id])
  @@index([invite_id])
}

model Sprint {
  id String @id @default(uuid())

  name String
  goal String?

  status SprintStatus @default(Planned)

  start_date DateTime
  end_date   DateTime

  completed_at DateTime?

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  tasks Task[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?

  @@index([project_id])
  @@index([project_id, status])
  @@index([project_id, start_date])
  @@index([project_id, end_date])
}

model TaskComment {
  id String @id @default(uuid())

  content Json

  task    Task   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  task_id String

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  reply_to_comment    TaskComment? @relation(fields: [reply_to_comment_id], references: [id], name: "TaskCommentReplies", onDelete: Cascade)
  reply_to_comment_id String?

  replied_comments TaskComment[] @relation("TaskCommentReplies")

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@index([task_id, reply_to_comment_id, created_at(sort: Desc), id(sort: Desc)])
  @@index([reply_to_comment_id, created_at(sort: Asc), id(sort: Asc)])
}

model TaskLabel {
  id String @id @default(uuid())

  name  String
  color String?

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id String

  tasks Task[]

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([name, project_id])
  @@index([name])
  @@index([project_id])
}
